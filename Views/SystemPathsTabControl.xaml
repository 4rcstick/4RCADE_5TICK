<UserControl x:Class="ArcadeStick.Views.SystemPathsTabControl"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:ArcadeStick.Views"
        mc:Ignorable="d" d:DesignHeight="450" d:DesignWidth="800">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="15">
            <TextBlock Text="SYSTEM PATHS" 
                       FontWeight="Bold" Margin="0,0,0,8"
                       FontSize="{Binding HeaderFontSize, FallbackValue=14}"
                       Foreground="{Binding HeaderColorHex, FallbackValue=#FFef44c3}"/>

            <TextBlock TextWrapping="Wrap" Margin="0,0,0,15"
                       FontSize="{Binding StandardFontSize, FallbackValue=13}"
                       Foreground="{Binding StandardColorHex, FallbackValue=#F2F2F7}"
                       Text="Set the folder locations for your ROMs, BIOS files, and CHDs. These can be absolute paths or relative to the ArcadeStick base directory. (Restart required for changes to take effect)"/>

            <Separator Background="{Binding BorderColorFramework, FallbackValue=#2C2C2E}" Margin="0,5,0,15"/>
            
            <TextBlock Text="ROMs Folder:" Foreground="{Binding SubHeaderColorHex, FallbackValue=#00D4FF}" FontSize="{Binding SubHeaderFontSize, FallbackValue=13}" Margin="0,0,0,5"/>
            <Grid Margin="0,0,0,15">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="50"/>
                </Grid.ColumnDefinitions>                
                <TextBox Grid.Column="0" x:Name="TxtRomsPath" Text=".\Data\roms" Background="#1C1C1E" Foreground="White" BorderBrush="#3A3A3C" Padding="4"/>
                <Button Grid.Column="1" x:Name="BtnBrowseRoms" Click="BtnBrowseDirectory_Click" Content="..." 
                        Style="{StaticResource ThemedActionButtonStyle}"
                        Background="{Binding BtnBgColorHex, FallbackValue=#2C2C2E}" 
                        Foreground="{Binding BtnTextColorNormalHex, FallbackValue=White}" 
                        BorderBrush="{Binding BtnBorderColorHex, FallbackValue=#3A3A3C}" BorderThickness="1"
                        Margin="5,0,0,0"/>
            </Grid>
            <TextBlock Text="BIOS Folder:" Foreground="{Binding SubHeaderColorHex, FallbackValue=#00D4FF}" FontSize="{Binding SubHeaderFontSize, FallbackValue=13}" Margin="0,0,0,5"/>
            <Grid Margin="0,0,0,15">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="50"/>
                </Grid.ColumnDefinitions>
                <TextBox Grid.Column="0" x:Name="TxtBiosPath" Text=".\Data\bios" Background="#1C1C1E" Foreground="White" BorderBrush="#3A3A3C" Padding="4"/>
                <Button Grid.Column="1" x:Name="BtnBrowseBios" Click="BtnBrowseDirectory_Click" Content="..." 
                        Style="{StaticResource ThemedActionButtonStyle}"
                        Background="{Binding BtnBgColorHex, FallbackValue=#2C2C2E}" 
                        Foreground="{Binding BtnTextColorNormalHex, FallbackValue=White}" 
                        BorderBrush="{Binding BtnBorderColorHex, FallbackValue=#3A3A3C}" BorderThickness="1"
                        Margin="5,0,0,0"/>
            </Grid>
            <TextBlock Text="CHD Folder:" Foreground="{Binding SubHeaderColorHex, FallbackValue=#00D4FF}" FontSize="{Binding SubHeaderFontSize, FallbackValue=13}" Margin="0,0,0,5"/>
            <Grid Margin="0,0,0,5">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="50"/>
                </Grid.ColumnDefinitions>
                <TextBox Grid.Column="0" x:Name="TxtChdPath" Text="" Background="#1C1C1E" Foreground="White" BorderBrush="#3A3A3C" Padding="4"/>
                <Button Grid.Column="1" x:Name="BtnBrowseChd" Click="BtnBrowseDirectory_Click" Content="..." 
                        Style="{StaticResource ThemedActionButtonStyle}"
                        Background="{Binding BtnBgColorHex, FallbackValue=#2C2C2E}" 
                        Foreground="{Binding BtnTextColorNormalHex, FallbackValue=White}" 
                        BorderBrush="{Binding BtnBorderColorHex, FallbackValue=#3A3A3C}" BorderThickness="1"
                        Margin="5,0,0,0"/>
            </Grid>
        </StackPanel>
    </ScrollViewer>
</UserControl>