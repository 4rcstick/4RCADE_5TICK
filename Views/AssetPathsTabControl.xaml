<UserControl x:Class="ArcadeStick.Views.AssetPathsTabControl"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:ArcadeStick.Views"
        mc:Ignorable="d" d:DesignHeight="450" d:DesignWidth="800">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="15">
            <TextBlock Text="ASSET PATHS" 
                       FontWeight="Bold" Margin="0,0,0,8"
                       FontSize="{Binding HeaderFontSize, FallbackValue=14}"
                       Foreground="{Binding HeaderColorHex, FallbackValue=#FFef44c3}"/>

            <TextBlock TextWrapping="Wrap" Margin="0,0,0,15"
                       FontSize="{Binding StandardFontSize, FallbackValue=13}"
                       Foreground="{Binding StandardColorHex, FallbackValue=#F2F2F7}"
                       Text="These asset paths have been structured to be in MAME's default folders for each asset.  If yours are somewhere else, you can change it here."/>

            <Separator Background="{Binding BorderColorFramework, FallbackValue=#2C2C2E}" Margin="0,5,0,15"/>
            
            
            <TextBlock Text="Marquees Folder:" Foreground="{Binding SubHeaderColorHex, FallbackValue=#00D4FF}" FontSize="{Binding SubHeaderFontSize, FallbackValue=13}" Margin="0,0,0,5"/>
            <Grid Margin="0,0,0,15">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="50"/>
                </Grid.ColumnDefinitions>
                <TextBox Grid.Column="0" x:Name="TxtMarqueesPath" Text=".\data\media\marquees" Background="#1C1C1E" Foreground="White" BorderBrush="#3A3A3C" Padding="4"/>
                <Button Grid.Column="1" x:Name="BtnBrowseMarquees" Click="BtnBrowseDirectory_Click" Content="..." 
                        Style="{StaticResource ThemedActionButtonStyle}"
                        Background="{Binding BtnBgColorHex, FallbackValue=#2C2C2E}" 
                        Foreground="{Binding BtnTextColorNormalHex, FallbackValue=White}" 
                        BorderBrush="{Binding BtnBorderColorHex, FallbackValue=#3A3A3C}" BorderThickness="1"
                        Margin="5,0,0,0"/>
            </Grid>

            <TextBlock Text="Videos Folder:" Foreground="{Binding SubHeaderColorHex, FallbackValue=#00D4FF}" FontSize="{Binding SubHeaderFontSize, FallbackValue=13}" Margin="0,0,0,5"/>
            <Grid Margin="0,0,0,15">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="50"/>
                </Grid.ColumnDefinitions>
                <TextBox Grid.Column="0" x:Name="TxtVideosPath" Text=".\data\media\videos" Background="#1C1C1E" Foreground="White" BorderBrush="#3A3A3C" Padding="4"/>
                <Button Grid.Column="1" x:Name="BtnBrowseVideos" Click="BtnBrowseDirectory_Click" Content="..." 
                        Style="{StaticResource ThemedActionButtonStyle}"
                        Background="{Binding BtnBgColorHex, FallbackValue=#2C2C2E}" 
                        Foreground="{Binding BtnTextColorNormalHex, FallbackValue=White}" 
                        BorderBrush="{Binding BtnBorderColorHex, FallbackValue=#3A3A3C}" BorderThickness="1"
                        Margin="5,0,0,0"/>
            </Grid>

            <TextBlock Text="Flyers Folder:" Foreground="{Binding SubHeaderColorHex, FallbackValue=#00D4FF}" FontSize="{Binding SubHeaderFontSize, FallbackValue=13}" Margin="0,0,0,5"/>
            <Grid Margin="0,0,0,15">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="50"/>
                </Grid.ColumnDefinitions>
                <TextBox Grid.Column="0" x:Name="TxtFlyersPath" Text=".\data\media\flyers" Background="#1C1C1E" Foreground="White" BorderBrush="#3A3A3C" Padding="4"/>
                <Button Grid.Column="1" x:Name="BtnBrowseFlyers" Click="BtnBrowseDirectory_Click" Content="..." 
                        Style="{StaticResource ThemedActionButtonStyle}"
                        Background="{Binding BtnBgColorHex, FallbackValue=#2C2C2E}" 
                        Foreground="{Binding BtnTextColorNormalHex, FallbackValue=White}" 
                        BorderBrush="{Binding BtnBorderColorHex, FallbackValue=#3A3A3C}" BorderThickness="1"
                        Margin="5,0,0,0"/>
            </Grid>

            <TextBlock Text="Gameplay Captures Folder:" Foreground="{Binding SubHeaderColorHex, FallbackValue=#00D4FF}" FontSize="{Binding SubHeaderFontSize, FallbackValue=13}" Margin="0,0,0,5"/>
            <Grid Margin="0,0,0,15">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="50"/>
                </Grid.ColumnDefinitions>
                <TextBox Grid.Column="0" x:Name="TxtGameplayPath" Text=".\data\media\gameplay" Background="#1C1C1E" Foreground="White" BorderBrush="#3A3A3C" Padding="4"/>
                <Button Grid.Column="1" x:Name="BtnBrowseGameplay" Click="BtnBrowseDirectory_Click" Content="..." 
                        Style="{StaticResource ThemedActionButtonStyle}"
                        Background="{Binding BtnBgColorHex, FallbackValue=#2C2C2E}" 
                        Foreground="{Binding BtnTextColorNormalHex, FallbackValue=White}" 
                        BorderBrush="{Binding BtnBorderColorHex, FallbackValue=#3A3A3C}" BorderThickness="1"
                        Margin="5,0,0,0"/>
            </Grid>

            <TextBlock Text="Title Screens Folder:" Foreground="{Binding SubHeaderColorHex, FallbackValue=#00D4FF}" FontSize="{Binding SubHeaderFontSize, FallbackValue=13}" Margin="0,0,0,5"/>
            <Grid Margin="0,0,0,15">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="50"/>
                </Grid.ColumnDefinitions>
                <TextBox Grid.Column="0" x:Name="TxtTitlescreensPath" Text=".\data\media\titlescreens" Background="#1C1C1E" Foreground="White" BorderBrush="#3A3A3C" Padding="4"/>
                <Button Grid.Column="1" x:Name="BtnBrowseTitlescreens" Click="BtnBrowseDirectory_Click" Content="..." 
                        Style="{StaticResource ThemedActionButtonStyle}"
                        Background="{Binding BtnBgColorHex, FallbackValue=#2C2C2E}" 
                        Foreground="{Binding BtnTextColorNormalHex, FallbackValue=White}" 
                        BorderBrush="{Binding BtnBorderColorHex, FallbackValue=#3A3A3C}" BorderThickness="1"
                        Margin="5,0,0,0"/>
            </Grid>

            <TextBlock Text="Cabinets Folder:" Foreground="{Binding SubHeaderColorHex, FallbackValue=#00D4FF}" FontSize="{Binding SubHeaderFontSize, FallbackValue=13}" Margin="0,0,0,5"/>
            <Grid Margin="0,0,0,5">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="50"/>
                </Grid.ColumnDefinitions>
                <TextBox Grid.Column="0" x:Name="TxtCabinetsPath" Text=".\data\media\cabinets" Background="#1C1C1E" Foreground="White" BorderBrush="#3A3A3C" Padding="4"/>
                <Button Grid.Column="1" x:Name="BtnBrowseCabinets" Click="BtnBrowseDirectory_Click" Content="..." 
                        Style="{StaticResource ThemedActionButtonStyle}"
                        Background="{Binding BtnBgColorHex, FallbackValue=#2C2C2E}" 
                        Foreground="{Binding BtnTextColorNormalHex, FallbackValue=White}" 
                        BorderBrush="{Binding BtnBorderColorHex, FallbackValue=#3A3A3C}" BorderThickness="1"
                        Margin="5,0,0,0"/>
            </Grid>

        </StackPanel>
    </ScrollViewer>
</UserControl>