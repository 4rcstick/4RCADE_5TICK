<UserControl x:Class="ArcadeStick.Views.FolderOrderTabControl"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:ArcadeStick.Views"
        mc:Ignorable="d" d:DesignHeight="450" d:DesignWidth="800">
    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="FOLDER ORDER" 
                   FontWeight="Bold" Margin="0,0,0,8"
                   FontSize="{Binding HeaderFontSize, FallbackValue=14}"
                   Foreground="{Binding HeaderColorHex, FallbackValue=#FFef44c3}"/>

        <TextBlock Grid.Row="1" TextWrapping="Wrap" Margin="0,0,0,15"
                   FontSize="{Binding StandardFontSize, FallbackValue=13}"
                   Foreground="{Binding StandardColorHex, FallbackValue=#F2F2F7}"
                   Text="To adjust what order the folders are displayed in the Game List Panel, select one below and use the up/down buttons to move it to it's desired position."/>

        <!-- [SECTION: Folder Order List + Controls] -->
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="240"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Displays the current folder order; selection drives BtnFolderUp/Down -->
            <ListBox x:Name="LstFolderOrder" Grid.Column="0" 
                     Background="#000000" Foreground="#F2F2F7" 
                     BorderBrush="#3A3A3C" BorderThickness="1" 
                     FontSize="14" FontWeight="Bold" Padding="5"/>

            <Grid Grid.Column="1" Margin="20,0,0,0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Reorder buttons: move the selected list item up/down -->
                <StackPanel Grid.Row="0" HorizontalAlignment="Left">
                    <Button x:Name="BtnFolderUp" Content="Up ▲" 
                            Width="100" Height="35" Margin="0,0,0,15"
                            Style="{StaticResource ThemedActionButtonStyle}"
                            Background="{Binding BtnBgColorHex, FallbackValue=#1C1C1E}" 
                            Foreground="{Binding BtnTextColorNormalHex, FallbackValue=#FFD60A}" 
                            BorderBrush="{Binding BtnBorderColorHex, FallbackValue=#FFD60A}" BorderThickness="1"
                            FontWeight="SemiBold" Click="BtnFolderUp_Click"/>

                    <Button x:Name="BtnFolderDown" Content="Down ▼" 
                            Width="100" Height="35" Margin="0,0,0,0"
                            Style="{StaticResource ThemedActionButtonStyle}"
                            Background="{Binding BtnBgColorHex, FallbackValue=#1C1C1E}" 
                            Foreground="{Binding BtnTextColorNormalHex, FallbackValue=#FFD60A}" 
                            BorderBrush="{Binding BtnBorderColorHex, FallbackValue=#FFD60A}" BorderThickness="1"
                            FontWeight="SemiBold" Click="BtnFolderDown_Click"/>
                </StackPanel>

                <!-- Persists the current list order to the folder_order config file -->
                <Button x:Name="BtnSaveFolderOrder" Content="Save Folders" 
                        Grid.Row="1" Width="120" Height="35" 
                        HorizontalAlignment="Left" VerticalAlignment="Bottom"
                        Style="{StaticResource ThemedActionButtonStyle}"
                        Background="{Binding BtnBgColorHex, FallbackValue=#1C1C1E}" 
                        Foreground="{Binding BtnTextColorNormalHex, FallbackValue=#00D4FF}" 
                        BorderBrush="{Binding BtnBorderColorHex, FallbackValue=#00D4FF}" BorderThickness="1"
                        FontWeight="SemiBold" Click="BtnSaveFolderOrder_Click"/>
            </Grid>
        </Grid>
        <!-- [END SECTION: Folder Order List + Controls] -->
    </Grid>
</UserControl>