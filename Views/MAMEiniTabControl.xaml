<UserControl x:Class="ArcadeStick.Views.MAMEiniTabControl"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:ArcadeStick.Views"
        mc:Ignorable="d" d:DesignHeight="450" d:DesignWidth="800">
    <Grid Margin="15">
        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <TextBlock Text="MAME.ini" 
                           FontWeight="Bold" Margin="0,0,0,8"
                           FontSize="{Binding HeaderFontSize, FallbackValue=14}"
                           Foreground="{Binding HeaderColorHex, FallbackValue=#FFef44c3}"/>

                <TextBlock TextWrapping="Wrap" Margin="0,0,0,15"
                           FontSize="{Binding StandardFontSize, FallbackValue=13}"
                           Foreground="{Binding StandardColorHex, FallbackValue=#F2F2F7}"
                           Text="These settings control the core MAME.ini options that govern video rendering and emulation behavior."/>

                <Separator Background="{Binding BorderColorFramework, FallbackValue=#2C2C2E}" Margin="0,5,0,15"/>
                
                <Grid Margin="0,0,0,25">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="180"/>
                        <ColumnDefinition Width="100"/>
                        <ColumnDefinition Width="180"/>
                        <ColumnDefinition Width="100"/>
                    </Grid.ColumnDefinitions>

                    <Label Content="Video OSD Renderer:" Grid.Column="0" Foreground="{Binding SubHeaderColorHex, FallbackValue=#00D4FF}" FontSize="{Binding SubHeaderFontSize, FallbackValue=13}" VerticalAlignment="Center"/>

                    <ComboBox x:Name="CboVideoMode" 
                              Grid.Column="1" 
                              Width="60" 
                              HorizontalAlignment="Left"
                              Height="25">
                        <ComboBoxItem Content="d3d"/>
                        <ComboBoxItem Content="opengl"/>
                        <ComboBoxItem Content="bgfx"/>
                        <ComboBoxItem Content="gdi"/>
                        <ComboBoxItem Content="none"/>
                    </ComboBox>

                    <Label Content="Frame Skipping:" Grid.Column="2" Foreground="{Binding SubHeaderColorHex, FallbackValue=#00D4FF}" FontSize="{Binding SubHeaderFontSize, FallbackValue=13}" VerticalAlignment="Center"/>

                    <ComboBox x:Name="CboFrameSkip" 
                              Grid.Column="3" 
                              Width="60" 
                              HorizontalAlignment="Left"
                              Height="25">
                        <ComboBoxItem Content="auto"/>
                        <ComboBoxItem Content="0"/>
                        <ComboBoxItem Content="1"/>
                        <ComboBoxItem Content="2"/>
                        <ComboBoxItem Content="3"/>
                        <ComboBoxItem Content="4"/>
                        <ComboBoxItem Content="5"/>
                        <ComboBoxItem Content="6"/>
                        <ComboBoxItem Content="7"/>
                        <ComboBoxItem Content="8"/>
                        <ComboBoxItem Content="9"/>
                        <ComboBoxItem Content="10"/>
                    </ComboBox>
                </Grid>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <CheckBox x:Name="ChkWindow" Grid.Row="0" Grid.Column="0" Content="Run in Windowed Mode" Foreground="{Binding StandardColorHex, FallbackValue=White}" FontSize="{Binding StandardFontSize, FallbackValue=13}" Margin="0,0,0,15" VerticalContentAlignment="Center"/>
                    <CheckBox x:Name="ChkCheat" Grid.Row="0" Grid.Column="1" Content="Enable Core Diagnostic Cheat Engines" Foreground="{Binding StandardColorHex, FallbackValue=White}" FontSize="{Binding StandardFontSize, FallbackValue=13}" Margin="0,0,0,15" VerticalContentAlignment="Center"/>

                    <CheckBox x:Name="ChkHlslEnable" Grid.Row="1" Grid.Column="0" Content="Enable CRT Scanline / Shaders Matrix" Foreground="{Binding StandardColorHex, FallbackValue=White}" FontSize="{Binding StandardFontSize, FallbackValue=13}" Margin="0,0,0,15" VerticalContentAlignment="Center"/>
                    <CheckBox x:Name="ChkKeepAspect" Grid.Row="1" Grid.Column="1" Content="Enforce Strict Pixel Aspect Ratios" Foreground="{Binding StandardColorHex, FallbackValue=White}" FontSize="{Binding StandardFontSize, FallbackValue=13}" Margin="0,0,0,15" VerticalContentAlignment="Center"/>

                    <CheckBox x:Name="ChkSkipGameInfo" Grid.Row="2" Grid.Column="0" Content="Skip Mandatory System Information Screen" Foreground="{Binding StandardColorHex, FallbackValue=White}" FontSize="{Binding StandardFontSize, FallbackValue=13}" Margin="0,0,0,15" VerticalContentAlignment="Center"/>
                    <CheckBox x:Name="ChkDisableThrottle" Grid.Row="2" Grid.Column="1" Content="Disable Throttling" Foreground="{Binding StandardColorHex, FallbackValue=White}" FontSize="{Binding StandardFontSize, FallbackValue=13}" Margin="0,0,0,15" VerticalContentAlignment="Center"/>

                    <CheckBox x:Name="ChkMultithreading" Grid.Row="3" Grid.Column="0" Content="Enable Multithreading" Foreground="{Binding StandardColorHex, FallbackValue=White}" FontSize="{Binding StandardFontSize, FallbackValue=13}" Margin="0,0,0,15" VerticalContentAlignment="Center"/>
                    <CheckBox x:Name="ChkVsync" Grid.Row="3" Grid.Column="1" Content="Enable Vertical Sync" Foreground="{Binding StandardColorHex, FallbackValue=White}" FontSize="{Binding StandardFontSize, FallbackValue=13}" Margin="0,0,0,15" VerticalContentAlignment="Center"/>

                    <CheckBox x:Name="ChkTripleBuffer" Grid.Row="4" Grid.Column="0" Content="Enable Triple Buffering" Foreground="{Binding StandardColorHex, FallbackValue=White}" FontSize="{Binding StandardFontSize, FallbackValue=13}" Margin="0,0,0,15" VerticalContentAlignment="Center"/>
                    <CheckBox x:Name="ChkSyncRefresh" Grid.Row="4" Grid.Column="1" Content="Synchronize Refresh Rate" Foreground="{Binding StandardColorHex, FallbackValue=White}" FontSize="{Binding StandardFontSize, FallbackValue=13}" Margin="0,0,0,15" VerticalContentAlignment="Center"/>
                </Grid>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>