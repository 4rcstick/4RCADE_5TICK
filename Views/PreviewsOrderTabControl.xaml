<UserControl x:Class="ArcadeStick.Views.PreviewsOrderTabControl"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:ArcadeStick.Views"
        mc:Ignorable="d" d:DesignHeight="450" d:DesignWidth="800">
    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="PREVIEWS ORDER" 
                   FontWeight="Bold" Margin="0,0,0,8"
                   FontSize="{Binding HeaderFontSize, FallbackValue=14}"
                   Foreground="{Binding HeaderColorHex, FallbackValue=#FFef44c3}"/>

        <TextBlock Grid.Row="1" TextWrapping="Wrap" Margin="0,0,0,15"
                   FontSize="{Binding StandardFontSize, FallbackValue=13}"
                   Foreground="{Binding StandardColorHex, FallbackValue=#F2F2F7}"
                   Text="To adjust what order the previews are displayed in the Preview Panel, select one below and use the up/down buttons to move it to it's desired position. The program will start with the top and work through each asset and display the first matching asset it finds. If none are found it will display the default &quot;no preview found&quot; Image, or you can select your own image in the THEMES tab."/>

        <!-- [SECTION: Preview Priority List + Controls] -->
        <!-- This order corresponds to PreviewPriorityOrder in MainViewModel, consumed by
             UpdateActiveMediaPreviews to decide which media type to show first for the selected game. -->
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="240"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Displays the current preview-type priority order; selection drives BtnMediaUp/Down -->
            <ListBox x:Name="LstMediaOrder" Grid.Column="0" 
                     Height="220" VerticalAlignment="Top"
                     Background="#000000" Foreground="#F2F2F7" 
                     BorderBrush="#3A3A3C" BorderThickness="1" 
                     FontSize="14" FontWeight="Bold" Padding="5"/>

            <StackPanel Grid.Column="1" Margin="20,0,0,0" HorizontalAlignment="Left">
                <!-- Reorder buttons: move the selected list item up/down -->
                <Button x:Name="BtnMediaUp" Content="Up ▲" 
                        Width="100" Height="35" Margin="0,0,0,15"
                        Style="{StaticResource ThemedActionButtonStyle}"
                        Background="{Binding BtnBgColorHex, FallbackValue=#1C1C1E}" 
                        Foreground="{Binding BtnTextColorNormalHex, FallbackValue=#FFD60A}" 
                        BorderBrush="{Binding BtnBorderColorHex, FallbackValue=#FFD60A}" BorderThickness="1"
                        FontWeight="SemiBold" Click="BtnMediaUp_Click"/>

                <Button x:Name="BtnMediaDown" Content="Down ▼" 
                        Width="100" Height="35" Margin="0,0,0,0"
                        Style="{StaticResource ThemedActionButtonStyle}"
                        Background="{Binding BtnBgColorHex, FallbackValue=#1C1C1E}" 
                        Foreground="{Binding BtnTextColorNormalHex, FallbackValue=#FFD60A}" 
                        BorderBrush="{Binding BtnBorderColorHex, FallbackValue=#FFD60A}" BorderThickness="1"
                        FontWeight="SemiBold" Click="BtnMediaDown_Click"/>

                <!-- Persists the current list order to preview_order.cfg -->
                <Button x:Name="BtnSaveMediaOrder" Content="Save Priority" 
                        Width="100" Height="35" Margin="0,100,0,0"
                        Style="{StaticResource ThemedActionButtonStyle}"
                        Background="{Binding BtnBgColorHex, FallbackValue=#1C1C1E}" 
                        Foreground="{Binding BtnTextColorNormalHex, FallbackValue=#00D4FF}" 
                        BorderBrush="{Binding BtnBorderColorHex, FallbackValue=#00D4FF}" BorderThickness="1"
                        FontWeight="SemiBold" Click="BtnSaveMediaOrder_Click"/>
            </StackPanel>
        </Grid>
        <!-- [END SECTION: Preview Priority List + Controls] -->
    </Grid>
</UserControl>