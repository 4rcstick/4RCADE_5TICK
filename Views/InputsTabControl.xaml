<UserControl x:Class="ArcadeStick.Views.InputsTabControl"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:ArcadeStick.Views"
        mc:Ignorable="d" d:DesignHeight="450" d:DesignWidth="800">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="15">

            <!-- [SECTION: Subsystem Configuration] -->
            <!-- Gamepad polling toggle + WGIService tuning values (device ID, deadzone, repeat timing, nav mode) -->
            <TextBlock Text="SUBSYSTEM CONFIGURATION" Foreground="{Binding HeaderColorHex, FallbackValue=#FFCC00}" FontWeight="Bold" FontSize="{Binding HeaderFontSize, FallbackValue=14}" Margin="0,0,0,12"/>

            <CheckBox x:Name="ChkGamepad" Content="Enable Gamepad Polling Subsystem" Foreground="#F2F2F7" FontSize="13" IsChecked="True" Margin="0,0,0,8"/>

            <!-- Which physical gamepad index to track (see WGIService.AssignTrackedGamepad) -->
            <Grid Margin="0,0,0,10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="220"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="DirectInput Device ID:" Foreground="{Binding StandardColorHex, FallbackValue=#00D4FF}" VerticalAlignment="Center" FontSize="{Binding StandardFontSize, FallbackValue=12}"/>
                <TextBox Grid.Column="1" x:Name="TxtDeviceID" Text="0" Background="#1C1C1E" Foreground="White" BorderBrush="#3A3A3C" Padding="4" Width="60" HorizontalAlignment="Left"/>
            </Grid>

            <!-- Analog stick deadzone threshold, as a percentage -->
            <Grid Margin="0,0,0,10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="220"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="Joystick Deadzone (%):" Foreground="{Binding StandardColorHex, FallbackValue=#00D4FF}" VerticalAlignment="Center" FontSize="{Binding StandardFontSize, FallbackValue=12}"/>
                <TextBox Grid.Column="1" x:Name="TxtJoystickDeadzone" Text="15" Background="#1C1C1E" Foreground="White" BorderBrush="#3A3A3C" Padding="4" Width="60" HorizontalAlignment="Left"/>
            </Grid>

            <!-- Delay before held-direction repeat navigation kicks in -->
            <Grid Margin="0,0,0,10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="220"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="Joystick Initial Delay (ms):" Foreground="{Binding StandardColorHex, FallbackValue=#00D4FF}" VerticalAlignment="Center" FontSize="{Binding StandardFontSize, FallbackValue=12}"/>
                <TextBox Grid.Column="1" x:Name="TxtJoystickInitialDelay" Text="500" Background="#1C1C1E" Foreground="White" BorderBrush="#3A3A3C" Padding="4" Width="60" HorizontalAlignment="Left"/>
            </Grid>

            <!-- Interval between repeat-navigation ticks once held-direction repeat is active -->
            <Grid Margin="0,0,0,10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="220"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="Joystick Repeat Delay (ms):" Foreground="{Binding StandardColorHex, FallbackValue=#00D4FF}" VerticalAlignment="Center" FontSize="{Binding StandardFontSize, FallbackValue=12}"/>
                <TextBox Grid.Column="1" x:Name="TxtJoystickDelay" Text="150" Background="#1C1C1E" Foreground="White" BorderBrush="#3A3A3C" Padding="4" Width="60" HorizontalAlignment="Left"/>
            </Grid>

            <!-- D-Pad / Analog / Both, controls which inputs ParseNavigation listens to -->
            <Grid Margin="0,0,0,15">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="220"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="Navigation Mode:" Foreground="{Binding StandardColorHex, FallbackValue=#00D4FF}" VerticalAlignment="Center" FontSize="{Binding StandardFontSize, FallbackValue=12}"/>
                <ComboBox Grid.Column="1" x:Name="CboNavigationMode" Width="150" Height="25" HorizontalAlignment="Left">
                    <ComboBoxItem Content="D-Pad &amp; Analog" IsSelected="True"/>
                    <ComboBoxItem Content="D-Pad Only"/>
                    <ComboBoxItem Content="Analog Only"/>
                </ComboBox>
            </Grid>
            <!-- [END SECTION: Subsystem Configuration] -->

            <Separator Background="{Binding BorderColorFramework, FallbackValue=#2C2C2E}" Margin="0,5,0,15"/>

            <!-- [SECTION: Diagnostics & Real-Time Feedback] -->
            <!-- Live-updated by WGIService.TriggerDiagnosticsUpdate (port dots/status) and
                 ActiveInputUpdated (input readout line) via WireLiveDiagnostics in code-behind. -->
            <TextBlock Text="DIAGNOSTICS &amp; REAL-TIME FEEDBACK" Foreground="{Binding HeaderColorHex, FallbackValue=#FFCC00}" FontWeight="Bold" FontSize="{Binding HeaderFontSize, FallbackValue=14}" Margin="0,0,0,12"/>

            <Border Background="#000000" Padding="10">
                <StackPanel>
                    <!-- Port 0 status dot + label -->
                    <Grid Margin="0,0,0,6">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="20"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Ellipse x:Name="DotPort0" Grid.Column="0" Width="10" Height="10" Fill="#A0A0A2" HorizontalAlignment="Left" VerticalAlignment="Center"/>
                        <TextBlock Text="Port 0:" Grid.Column="1" Foreground="#F2F2F7" FontSize="13" FontWeight="Bold" Margin="0,0,8,0" VerticalAlignment="Center"/>
                        <TextBlock x:Name="TxtPort0Status" Grid.Column="2" Text="No device detected" Foreground="#A0A0A2" FontSize="13" VerticalAlignment="Center"/>
                    </Grid>

                    <!-- Port 1 status dot + label -->
                    <Grid Margin="0,0,0,6">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="20"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Ellipse x:Name="DotPort1" Grid.Column="0" Width="10" Height="10" Fill="#A0A0A2" HorizontalAlignment="Left" VerticalAlignment="Center"/>
                        <TextBlock Text="Port 1:" Grid.Column="1" Foreground="#F2F2F7" FontSize="13" FontWeight="Bold" Margin="0,0,8,0" VerticalAlignment="Center"/>
                        <TextBlock x:Name="TxtPort1Status" Grid.Column="2" Text="No device detected" Foreground="#A0A0A2" FontSize="13" VerticalAlignment="Center"/>
                    </Grid>

                    <!-- Port 2 status dot + label -->
                    <Grid Margin="0,0,0,6">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="20"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Ellipse x:Name="DotPort2" Grid.Column="0" Width="10" Height="10" Fill="#A0A0A2" HorizontalAlignment="Left" VerticalAlignment="Center"/>
                        <TextBlock Text="Port 2:" Grid.Column="1" Foreground="#F2F2F7" FontSize="13" FontWeight="Bold" Margin="0,0,8,0" VerticalAlignment="Center"/>
                        <TextBlock x:Name="TxtPort2Status" Grid.Column="2" Text="No device detected" Foreground="#A0A0A2" FontSize="13" VerticalAlignment="Center"/>
                    </Grid>

                    <!-- Port 3 status dot + label -->
                    <Grid Margin="0,0,0,6">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="20"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Ellipse x:Name="DotPort3" Grid.Column="0" Width="10" Height="10" Fill="#A0A0A2" HorizontalAlignment="Left" VerticalAlignment="Center"/>
                        <TextBlock Text="Port 3:" Grid.Column="1" Foreground="#F2F2F7" FontSize="13" FontWeight="Bold" Margin="0,0,8,0" VerticalAlignment="Center"/>
                        <TextBlock x:Name="TxtPort3Status" Grid.Column="2" Text="No device detected" Foreground="#A0A0A2" FontSize="13" VerticalAlignment="Center"/>
                    </Grid>

                    <!-- Live readout of currently active button/stick input (from ActiveInputUpdated) -->
                    <Grid Margin="5,10,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" x:Name="TxtActiveInputReadout" Text="—" Foreground="#00D4FF" FontSize="{Binding SubHeaderFontSize, FallbackValue=13}" FontWeight="Bold"/>
                    </Grid>
                </StackPanel>
            </Border>
            <!-- [END SECTION: Diagnostics & Real-Time Feedback] -->

        </StackPanel>
    </ScrollViewer>
</UserControl>